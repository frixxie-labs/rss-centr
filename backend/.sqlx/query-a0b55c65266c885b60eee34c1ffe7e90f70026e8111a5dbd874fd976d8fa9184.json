{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id as \"id!: i64\",\n               feed_id as \"feed_id!: i64\",\n               external_id, title, url,\n               inserted_at as \"inserted_at: _\"\n        FROM feed_items\n        WHERE inserted_at >= NOW() - INTERVAL '24 hours'\n        ORDER BY inserted_at DESC, id DESC\n        ",
