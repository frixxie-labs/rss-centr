  "query": "\n        SELECT id as \"id!: i64\",\n               url,\n               title,\n               site_url,\n               etag,\n               last_modified,\n               poll_interval_seconds,\n               is_enabled as \"is_enabled!: bool\",\n               last_checked_at as \"last_checked_at: _\",\n               last_success_at as \"last_success_at: _\",\n               last_inserted_at as \"last_inserted_at: _\",\n               failure_count\n        FROM feeds\n        WHERE is_enabled = TRUE\n        ORDER BY id ASC\n        ",
